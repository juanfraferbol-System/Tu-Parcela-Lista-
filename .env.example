# SUPABASE (Base de Datos y Autenticación)
# La URL de tu proyecto en Supabase (Se usa en frontend y backend)
TPL_SUPABASE_URL=https://tu-proyecto.supabase.co
# La clave anónima pública (Seguro para usar en el frontend con RLS activado)
TPL_SUPABASE_ANON_KEY=tu_clave_anonima_publica_aqui
# La clave de servicio (NUNCA EXPONER EN EL FRONTEND, solo para Edge Functions o Servidor)
SUPABASE_SERVICE_ROLE_KEY=tu_clave_de_servicio_secreta_aqui

# GENERAL
# URL principal de la aplicación
APP_URL=https://tuparcelalista.cl
# Correo del administrador principal del CRM
ADMIN_EMAIL=juanfraferbol@gmail.com

# INTEGRACIONES OPCIONALES (Para segunda etapa de automatizaciones)
# Proveedor de correos (Resend, SendGrid)
EMAIL_PROVIDER_API_KEY=tu_api_key_de_correo
# Token de proveedor de WhatsApp (Si se usa API Oficial en lugar de wa.me)
WHATSAPP_PROVIDER_TOKEN=tu_token_de_whatsapp
# Pasarela de pagos (Flow, Transbank)
PAYMENT_PROVIDER_KEY=tu_key_de_pago
